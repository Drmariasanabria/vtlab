diff --git a/rooms/phonetics-whovian-vault/style.css b/rooms/phonetics-whovian-vault/style.css
new file mode 100644
index 0000000..0b2e9c6
--- /dev/null
+++ b/rooms/phonetics-whovian-vault/style.css
@@ -0,0 +1,488 @@
+:root {
+  color-scheme: dark;
+  --bg: #070914;
+  --panel: rgba(12, 20, 38, 0.74);
+  --panel-strong: rgba(13, 22, 42, 0.92);
+  --ink: #f7fbff;
+  --muted: #a9b8d0;
+  --cyan: #65e7ff;
+  --lime: #b9ff72;
+  --rose: #ff6fbd;
+  --line: rgba(255, 255, 255, 0.16);
+  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html {
+  scroll-behavior: smooth;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  background:
+    radial-gradient(circle at 50% 20%, rgba(101, 231, 255, 0.2), transparent 24rem),
+    radial-gradient(circle at 88% 68%, rgba(255, 111, 189, 0.16), transparent 22rem),
+    linear-gradient(135deg, #070914, #111a2b 48%, #08111f);
+  color: var(--ink);
+}
+
+body::before {
+  position: fixed;
+  inset: 0;
+  z-index: -1;
+  content: "";
+  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.7) 0 1px, transparent 1px);
+  background-size: 44px 44px;
+  opacity: 0.22;
+  animation: starDrift 24s linear infinite;
+}
+
+a,
+button,
+input,
+select,
+textarea {
+  font: inherit;
+}
+
+a {
+  color: inherit;
+}
+
+button {
+  cursor: pointer;
+}
+
+.skip-link {
+  position: absolute;
+  left: 16px;
+  top: 12px;
+  z-index: 20;
+  transform: translateY(-150%);
+  background: white;
+  color: #061018;
+  padding: 10px 14px;
+  border-radius: 999px;
+}
+
+.skip-link:focus {
+  transform: none;
+}
+
+.room-shell {
+  width: min(1180px, calc(100% - 36px));
+  margin: 0 auto;
+}
+
+.splash {
+  position: relative;
+  min-height: 86vh;
+  display: grid;
+  grid-template-rows: auto 1fr;
+  overflow: hidden;
+  padding: 24px 0 70px;
+}
+
+.room-nav {
+  display: flex;
+  justify-content: space-between;
+  gap: 16px;
+  color: var(--muted);
+  font-size: 0.94rem;
+}
+
+.room-nav a {
+  color: var(--ink);
+  font-weight: 800;
+  text-decoration: none;
+}
+
+.splash__content {
+  position: relative;
+  z-index: 1;
+  align-self: center;
+  width: min(850px, 100%);
+}
+
+.kicker {
+  margin: 0 0 14px;
+  color: var(--lime);
+  font-size: 0.8rem;
+  font-weight: 800;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+}
+
+h1,
+h2,
+h3 {
+  margin: 0;
+  font-family: "Space Grotesk", Inter, sans-serif;
+  line-height: 1;
+  letter-spacing: 0;
+}
+
+h1 {
+  max-width: 920px;
+  font-size: clamp(4rem, 11vw, 9rem);
+  text-shadow: 0 0 44px rgba(101, 231, 255, 0.42);
+}
+
+h2 {
+  font-size: clamp(2.2rem, 5vw, 4.2rem);
+}
+
+h3 {
+  font-size: 1.45rem;
+}
+
+.splash p,
+.lock-panel p,
+.completion p {
+  color: var(--muted);
+  font-size: 1.05rem;
+  line-height: 1.7;
+}
+
+.splash__actions,
+.mission__actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 12px;
+  margin-top: 28px;
+}
+
+.button,
+.export-grid button {
+  min-height: 46px;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  border: 1px solid transparent;
+  border-radius: 999px;
+  padding: 0 20px;
+  font-weight: 800;
+  text-decoration: none;
+  transition: transform 170ms ease, box-shadow 170ms ease, border-color 170ms ease;
+}
+
+.button:hover,
+.button:focus-visible,
+.export-grid button:hover,
+.export-grid button:focus-visible {
+  transform: translateY(-2px);
+}
+
+.button--primary {
+  background: linear-gradient(135deg, var(--cyan), var(--lime));
+  color: #061018;
+  box-shadow: 0 18px 40px rgba(101, 231, 255, 0.24);
+}
+
+.button--ghost,
+.export-grid button {
+  border-color: var(--line);
+  background: rgba(255, 255, 255, 0.07);
+  color: #e9f2ff;
+}
+
+.time-core {
+  position: absolute;
+  right: 2%;
+  top: 18%;
+  width: min(48vw, 520px);
+  aspect-ratio: 1;
+  border: 1px solid rgba(101, 231, 255, 0.22);
+  border-radius: 50%;
+  opacity: 0.62;
+  animation: rotateCore 18s linear infinite;
+}
+
+.time-core span {
+  position: absolute;
+  inset: 12%;
+  border: 1px dashed rgba(255, 255, 255, 0.22);
+  border-radius: 50%;
+}
+
+.time-core span:nth-child(2) {
+  inset: 26%;
+  border-color: rgba(185, 255, 114, 0.34);
+}
+
+.time-core span:nth-child(3) {
+  inset: 40%;
+  background: radial-gradient(circle, rgba(101, 231, 255, 0.45), transparent 60%);
+  border-style: solid;
+}
+
+.mission {
+  padding: 40px 0 72px;
+}
+
+.mission__header {
+  display: flex;
+  align-items: end;
+  justify-content: space-between;
+  gap: 20px;
+  margin-bottom: 24px;
+}
+
+.score {
+  min-width: 130px;
+  padding: 15px;
+  border: 1px solid var(--line);
+  border-radius: 18px;
+  background: rgba(255, 255, 255, 0.08);
+  text-align: center;
+}
+
+.score span {
+  display: block;
+  color: var(--muted);
+  font-size: 0.78rem;
+  font-weight: 800;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+}
+
+.score strong {
+  display: block;
+  margin-top: 4px;
+  font-size: 1.35rem;
+}
+
+.lock-panel,
+.chamber,
+.completion,
+.exports {
+  border: 1px solid rgba(255, 255, 255, 0.17);
+  border-radius: 24px;
+  background: linear-gradient(145deg, rgba(255, 255, 255, 0.13), rgba(255, 255, 255, 0.05));
+  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.34);
+  backdrop-filter: blur(18px);
+}
+
+.lock-panel,
+.completion,
+.exports {
+  padding: clamp(22px, 4vw, 38px);
+}
+
+.chamber-grid > div {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 16px;
+}
+
+.chamber {
+  display: grid;
+  gap: 14px;
+  padding: 22px;
+}
+
+.chamber label {
+  color: #edf5ff;
+  font-weight: 800;
+  line-height: 1.3;
+}
+
+.chamber input {
+  min-height: 46px;
+  width: 100%;
+  border: 1px solid rgba(255, 255, 255, 0.18);
+  border-radius: 14px;
+  background: rgba(255, 255, 255, 0.09);
+  color: var(--ink);
+  padding: 0 14px;
+}
+
+.hint {
+  color: var(--muted);
+  font-size: 0.93rem;
+}
+
+.feedback {
+  min-height: 22px;
+  font-weight: 800;
+}
+
+.feedback.is-correct {
+  color: var(--lime);
+}
+
+.feedback.is-wrong {
+  color: var(--rose);
+}
+
+.completion,
+.exports {
+  margin-top: 18px;
+}
+
+.export-grid {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 12px;
+  margin-top: 18px;
+}
+
+.export-grid button {
+  border-radius: 16px;
+  padding: 14px 16px;
+}
+
+.questionnaire {
+  width: min(920px, calc(100% - 28px));
+  max-height: 90vh;
+  overflow: auto;
+  border: 1px solid rgba(255, 255, 255, 0.18);
+  border-radius: 24px;
+  background: var(--panel-strong);
+  color: var(--ink);
+  box-shadow: 0 24px 90px rgba(0, 0, 0, 0.58);
+}
+
+.questionnaire::backdrop {
+  background: rgba(2, 5, 12, 0.76);
+  backdrop-filter: blur(8px);
+}
+
+.questionnaire form {
+  display: grid;
+  gap: 18px;
+  padding: clamp(18px, 4vw, 34px);
+}
+
+.questionnaire__intro {
+  display: grid;
+  gap: 10px;
+  margin-bottom: 4px;
+}
+
+.questionnaire__intro p {
+  margin: 0;
+  color: var(--muted);
+  line-height: 1.6;
+}
+
+.consent {
+  padding: 14px;
+  border: 1px solid rgba(185, 255, 114, 0.28);
+  border-radius: 16px;
+  background: rgba(185, 255, 114, 0.08);
+  color: #e8ffcd;
+  line-height: 1.55;
+}
+
+.field {
+  display: grid;
+  gap: 8px;
+}
+
+.field label,
+.likert legend {
+  font-weight: 800;
+}
+
+.field input,
+.field select,
+.field textarea {
+  width: 100%;
+  border: 1px solid rgba(255, 255, 255, 0.18);
+  border-radius: 14px;
+  background: rgba(255, 255, 255, 0.09);
+  color: var(--ink);
+  padding: 12px 14px;
+}
+
+.field textarea {
+  min-height: 90px;
+  resize: vertical;
+}
+
+.likert {
+  display: grid;
+  gap: 10px;
+  margin: 0;
+  padding: 14px;
+  border: 1px solid rgba(255, 255, 255, 0.13);
+  border-radius: 16px;
+}
+
+.likert__options {
+  display: grid;
+  grid-template-columns: repeat(5, minmax(0, 1fr));
+  gap: 8px;
+}
+
+.likert__options label {
+  display: grid;
+  gap: 5px;
+  place-items: center;
+  min-height: 58px;
+  border: 1px solid rgba(255, 255, 255, 0.13);
+  border-radius: 12px;
+  background: rgba(255, 255, 255, 0.06);
+  color: var(--muted);
+  font-size: 0.82rem;
+}
+
+.questionnaire__actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 12px;
+  justify-content: flex-end;
+  margin-top: 8px;
+}
+
+@keyframes rotateCore {
+  to { transform: rotate(360deg); }
+}
+
+@keyframes starDrift {
+  to { background-position: 88px 88px; }
+}
+
+@media (max-width: 820px) {
+  .splash {
+    min-height: 82vh;
+  }
+
+  .room-nav,
+  .mission__header {
+    align-items: start;
+    flex-direction: column;
+  }
+
+  .time-core {
+    right: -24%;
+    top: 14%;
+    width: 84vw;
+  }
+
+  .chamber-grid > div,
+  .export-grid,
+  .likert__options {
+    grid-template-columns: 1fr;
+  }
+
+  .button,
+  .export-grid button {
+    width: 100%;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    animation-duration: 1ms !important;
+    scroll-behavior: auto !important;
+    transition-duration: 1ms !important;
+  }
+}
