+          <button class="button button--primary" type="button" data-open-pre>Open pre-questionnaire</button>
+        </div>
+
+        <form class="chamber-grid" id="mission-form" hidden>
+          <div id="chambers"></div>
+          <div class="mission__actions">
+            <button class="button button--primary" type="submit">Complete Mission</button>
+            <button class="button button--ghost" type="button" data-open-post>Exit + post-questionnaire</button>
+          </div>
+        </form>
+
+        <section class="completion" id="completion" hidden aria-live="polite">
+          <h3>Vault sequence complete</h3>
+          <p>Your demo run is complete. Please submit the post-task questionnaire to unlock export options.</p>
+          <button class="button button--primary" type="button" data-open-post>Open post-questionnaire</button>
+        </section>
+
+        <section class="exports" id="exports" hidden aria-labelledby="exports-title">
+          <h3 id="exports-title">Export options</h3>
+          <div class="export-grid">
+            <button type="button" data-export="pre-pdf">Export pre-questionnaire as PDF</button>
+            <button type="button" data-export="pre-word">Export pre-questionnaire as Word</button>
+            <button type="button" data-export="post-pdf">Export post-questionnaire as PDF</button>
+            <button type="button" data-export="post-word">Export post-questionnaire as Word</button>
+            <button type="button" data-export="combined-pdf">Export combined pre/post research report as PDF</button>
+            <button type="button" data-export="combined-word">Export combined pre/post research report as Word</button>
+          </div>
+        </section>
+      </section>
+    </main>
+
+    <dialog class="questionnaire" id="pre-dialog" aria-labelledby="pre-title">
+      <form method="dialog" id="pre-form"></form>
